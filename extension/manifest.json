{
  "manifest_version": 3,
  "name": "YouTube Transcript Search",
  "version": "2.0",
  "description": "Search YouTube transcripts by keyword and jump to exact timestamps.",
  "permissions": ["activeTab", "storage", "tabs", "scripting"],
  "host_permissions": [
    "*://*.youtube.com/*",
    "http://localhost:5000/*",
    "http://127.0.0.1:5000/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html"
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "content_scripts": [
    {
      "matches": ["*://*.youtube.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
